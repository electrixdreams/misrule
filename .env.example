# Default live provider. Browser Settings may override these public values for
# one tab; browser-entered keys are held in memory and are never persisted.
MISRULE_PROVIDER=openrouter
MISRULE_API_ENDPOINT=https://openrouter.ai/api/v1
MISRULE_MODEL=openai/gpt-oss-20b:free

# Comma-separated exact host allowlist for server-side provider calls. Add a
# trusted OpenAI-compatible host here before selecting it in browser Settings.
MISRULE_ALLOWED_PROVIDER_HOSTS=openrouter.ai,api.openai.com

# Default server-side credential for OpenRouter. Keep secret and never prefix
# it with NEXT_PUBLIC_. A user may instead supply a session-only key in Settings.
OPENROUTER_API_KEY=

# Used when MISRULE_PROVIDER=openai-compatible. OPENAI_API_KEY is accepted as a
# legacy fallback, but this explicit name is preferred.
OPENAI_COMPATIBLE_API_KEY=

# live is the production default. mock is for deterministic local QA only.
MISRULE_AUDIT_MODE=live

# Optional directory for server-side proof evidence. Raw provider responses may
# contain sensitive story material, so do not mount this as a public directory.
MISRULE_EVIDENCE_DIR=

# Required only if a same-build captured fallback is later created.
MISRULE_FALLBACK_SECRET=
