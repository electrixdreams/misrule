# Required for live audits. Keep server-side only.
OPENAI_API_KEY=

# Brief 09 locks the flagship GPT-5.6 model.
OPENAI_MODEL=gpt-5.6-sol

# live is the production default. mock is for deterministic local QA only.
MISRULE_AUDIT_MODE=live

# Optional directory for server-side, public-safe proof evidence.
MISRULE_EVIDENCE_DIR=

# Required only if a same-build captured fallback is later created.
MISRULE_FALLBACK_SECRET=
